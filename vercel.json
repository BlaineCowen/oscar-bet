{
  "buildCommand": "prisma generate && next build",
  "crons": [
    {
      "path": "/api/cron/sync-odds",
      "schedule": "*/5 * * * *"
    }
  ],
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["sfo1"],
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
